# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Cargo lock is kept for binaries (intentionally NOT ignored)

# Insta pending snapshots
**/*.snap.new
**/.snapshots/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Local scratch
/tmp/
*.log

# PDFs generated by E2E tests
tests/fixtures/*.pdf

# Coverage reports generated by cargo-tarpaulin
lcov.info
tarpaulin-report.html

# Read-only C# reference implementation we port from — kept on disk, not tracked.
/.reference/
# rp1 directory
!.rp1/
.rp1/*
!.rp1/project_id
